# ─── SERVER ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── DATABASE ─────────────────────────────────────────────────────────────────
# SQLite (default, zero-config, great for self-hosting)
DB_PATH=./data/dealdekho.db

# ─── SCRAPING STRATEGY ────────────────────────────────────────────────────────
# Options: "playwright" | "proxy_api"
# Use "playwright" for self-hosted (free, needs browser)
# Use "proxy_api" for scale (paid, more reliable)
SCRAPE_MODE=playwright

# ─── PROXY API (optional, for scale) ─────────────────────────────────────────
# Sign up at https://oxylabs.io or https://scraperapi.com
# PROXY_API_KEY=your_api_key_here
# PROXY_API_URL=https://realtime.oxylabs.io/v1/queries

# ─── SCRAPING SCHEDULE (cron syntax) ─────────────────────────────────────────
# Default: every 6 hours
SCRAPE_CRON=0 */6 * * *

# ─── RATE LIMITING ────────────────────────────────────────────────────────────
# Delay between requests in ms (be polite to servers)
SCRAPE_DELAY_MS=3000
# Max concurrent scrapers
SCRAPE_CONCURRENCY=2

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Your frontend URL (comma-separated for multiple)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
